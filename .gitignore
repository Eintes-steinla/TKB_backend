# Thư mục chứa các thư viện tải về (Cực kỳ nặng, không bao giờ đẩy lên Git)
node_modules/
jspm_packages/

# Chặn toàn bộ các file cấu hình môi trường nhạy cảm (Tránh lộ mật khẩu DB, JWT Secret)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Thư mục chứa code JavaScript sau khi biên dịch từ TypeScript (nếu có build)
dist/
build/
out/

# Log lỗi của hệ thống hoặc của npm trong quá trình chạy ứng dụng
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# Cấu hình riêng của các IDE / Text Editor (VS Code, IntelliJ) dưới máy cá nhân
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Hệ điều hành tự sinh ra
.DS_Store
Thumbs.db